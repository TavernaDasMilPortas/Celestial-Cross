  m_Script: {fileID: 11500000, guid: 8f682c46c2f408c4e8b31de2b3ce2914, type: 3}
  m_Name: ChibiTestDialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  entries:
  - speakerName: Shany
    dialogueText: "Ol\xE1, que bom que apareceu!"
    characterSprite: {fileID: 21300000, guid: 171580878dc9f9043ac9929348b8e850, type: 3}
    choices: []
    flagToSet: 
  - speakerName: Shany
    dialogueText: Vamos ir em uma aventura hoje?
    characterSprite: {fileID: 21300000, guid: 171580878dc9f9043ac9929348b8e850, type: 3}
    choices:
    - choiceText: Sim
      responseEntries:
      - speakerName: Shany
        dialogueText: "Que \xF3timo, mal posso esperar para ver qual planeta explorar!"
        characterSprite: {fileID: 21300000, guid: 171580878dc9f9043ac9929348b8e850, type: 3}
        choices: []
        flagToSet: 
      flagToSet: aceitou_shany
      requiredFlags: []
      blockedByFlags: []
    - choiceText: "N\xE3o"
      responseEntries:
      - speakerName: Shany
        dialogueText: "Tudo bem, fica para a pr\xF3xima ent\xE3o."
        characterSprite: {fileID: 21300000, guid: 171580878dc9f9043ac9929348b8e850, type: 3}
        choices: []
        flagToSet: 
      flagToSet: recusou_shany
      requiredFlags: []
      blockedByFlags: []
    flagToSet: 
  - speakerName: Shany
    dialogueText: Nos encontramos de novo! O que gostaria de fazer?
    characterSprite: {fileID: 21300000, guid: 171580878dc9f9043ac9929348b8e850, type: 3}
    choices:
    - choiceText: Vamos para Witch Woo?
      responseEntries:
      - speakerName: Shany
        dialogueText: "Vamos! Estava morrendo de vontade de explorar l\xE1!"
        characterSprite: {fileID: 21300000, guid: 171580878dc9f9043ac9929348b8e850, type: 3}
        choices: []
        flagToSet: 
      flagToSet: 
      requiredFlags:
      - aceitou_shany
      blockedByFlags:
      - recusou_shany
    - choiceText: Estava ocupada antes, me desculpa.
      responseEntries:
      - speakerName: Shany
        dialogueText: Tudo bem, eu entendo.
        characterSprite: {fileID: 21300000, guid: 171580878dc9f9043ac9929348b8e850, type: 3}
        choices: []
        flagToSet: 
      flagToSet: desculpou_shany
      requiredFlags:
      - recusou_shany
      blockedByFlags: []
    flagToSet: 
