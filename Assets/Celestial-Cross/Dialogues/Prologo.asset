  nodeData:
  - guid: 9db0a7f8-0705-4542-af66-0b8a27046ae8
    nodeType: 1
    position: {x: 299, y: 168}
    speakerName: Lillie
    dialogueText: Alexander, can you tell that story again?
    characterSprite: {fileID: 0}
    sceneryId: 
    choices: []
