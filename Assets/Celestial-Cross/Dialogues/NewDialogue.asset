    nodeType: 1
    position: {x: 7943, y: 192}
    speakerName: Lidell
    dialogueText: "I\u2019m not looking to accuse anyone, I'd just like to know if
      you have any type of knowledge about it."
    characterSprite: {fileID: 21300000, guid: 566d18f891d0f1a48a89c8ef7af99aad, type: 3}
