  - guid: b7bb6687-dcf1-4b2c-b7bb-60be717cfc44
    nodeType: 1
    position: {x: 4034, y: 199}
    speakerName: Lidell
    dialogueText: Not this time, I actually came here to ask you about some recent
      findings.
    characterSprite: {fileID: 21300000, guid: 566d18f891d0f1a48a89c8ef7af99aad, type: 3}
    sceneryId: 
    choices: []
    conditionVariable: 
