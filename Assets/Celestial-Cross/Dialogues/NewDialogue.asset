  - guid: 4197c3ba-af5b-4799-9516-dcbb3d235240
    nodeType: 1
    position: {x: 4775, y: 200}
    speakerName: Lidell
    dialogueText: You see, we found one of the couches on the student council run
      was covered in scratches earlier today.
    characterSprite: {fileID: 21300000, guid: 28b9d359da3612e468ec877807cc2ad6, type: 3}
    sceneryId: 
    choices: []
    conditionVariable: 
