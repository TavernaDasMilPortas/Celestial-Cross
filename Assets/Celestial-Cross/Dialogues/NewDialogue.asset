    actionValue: 
    actionType: 0
    variableName: 
    compareValue: 
  - guid: 65d2ab03-f2fe-462b-a53c-bea0afe185c6
    nodeType: 1
    position: {x: 7138, y: 191}
    speakerName: Marie
    dialogueText: "Besides, if you\u2019re looking to accuse me, I can assure you
      I have a solid alibi."
    characterSprite: {fileID: 21300000, guid: 3534347e118f1f74e8b5511cb3a3b179, type: 3}
