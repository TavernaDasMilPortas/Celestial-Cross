  - guid: 0f13324c-ae30-43c8-896b-3097ded15c5b
    nodeType: 1
    position: {x: 6283, y: 193}
    speakerName: Marie
    dialogueText: Why exactly would I know anything about that? It's not like I keep
      track of all of the cats around Astra Alis.
    characterSprite: {fileID: 21300000, guid: 1f9fd67bd5623d148b1005296b27b855, type: 3}
    sceneryId: 
    choices: []
    conditionVariable: 
    conditionValue: 
