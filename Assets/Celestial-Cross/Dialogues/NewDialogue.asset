  - guid: 7dd3836d-5c5c-462e-8279-e7185d93956d
    nodeType: 1
    position: {x: 5622, y: 195}
    speakerName: Lidell
    dialogueText: You wouldn't happen to know anything about that, would you?
    characterSprite: {fileID: 21300000, guid: 566d18f891d0f1a48a89c8ef7af99aad, type: 3}
    sceneryId: 
    choices: []
    conditionVariable: 
