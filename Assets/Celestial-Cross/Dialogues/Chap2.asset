    nodeType: 1
    position: {x: 0, y: 0}
    speakerName: Magnolia
    dialogueText: "So why don\u2019t you all stretch those legs and get to work."
    characterSprite: {fileID: 21300000, guid: b7d12cd161dca5a4ca2c791e691c0a13, type: 3}
    sceneryId: interior
