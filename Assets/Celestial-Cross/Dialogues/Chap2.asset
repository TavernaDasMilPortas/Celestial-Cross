    actionType: 0
    variableName: 
    compareValue: 
  - guid: 1e667400-d4f7-46fa-b6de-8360e20578ad
    nodeType: 1
    position: {x: 0, y: 0}
    speakerName: 'Magnolia '
    dialogueText: "From the new arrivals to the old faces, i\u2019d like to thank
      everyone for coming to our prestigious school."
    characterSprite: {fileID: 21300000, guid: b7d12cd161dca5a4ca2c791e691c0a13, type: 3}
    sceneryId: interior
    choices: []
    conditionVariable: 
    conditionValue: 
    conditionType: 0
    conditionPorts: []
    actionVariable: 
    actionValue: 
    actionType: 0
    variableName: 
    compareValue: 
  - guid: fba624c4-9007-4a1f-bed0-5c6b6208f40f
    nodeType: 1
    position: {x: 0, y: 0}
    speakerName: Magnolia
    dialogueText: "Each one of us is here because you\u2019ve been chosen by a celestia,
      that itself is considered a great achievement across the various planets that
      form the celestial cross."
    characterSprite: {fileID: 0}
    sceneryId: interior
    choices: []
    conditionVariable: 
    conditionValue: 
    conditionType: 0
    conditionPorts: []
    actionVariable: 
    actionValue: 
    actionType: 0
    variableName: 
    compareValue: 
  - guid: b293adaa-53e5-400b-8467-53f33a71e4f7
    nodeType: 1
    position: {x: 0, y: 0}
    speakerName: Magnolia
    dialogueText: "In the forest, your upperclassman Morgan Novalin has hidden a
      great bunch of his little \u201CInvaders\u201D for you to catch."
    characterSprite: {fileID: 21300000, guid: b7d12cd161dca5a4ca2c791e691c0a13, type: 3}
    sceneryId: interior
    choices: []
    conditionVariable: 
    conditionValue: 
    conditionType: 0
    conditionPorts: []
    actionVariable: 
    actionValue: 
    actionType: 0
    variableName: 
    compareValue: 
  - guid: 4e32dded-aa5f-48f8-97af-965235479f73
    nodeType: 1
    position: {x: 0, y: 0}
    speakerName: Magnolia
    dialogueText: "To better access each of you, i\u2019d like to propose a small
      little challenge."
    characterSprite: {fileID: 21300000, guid: b7d12cd161dca5a4ca2c791e691c0a13, type: 3}
    sceneryId: interior
    choices: []
    conditionVariable: 
    conditionValue: 
    conditionType: 0
    conditionPorts: []
    actionVariable: 
    actionValue: 
    actionType: 0
    variableName: 
    compareValue: 
