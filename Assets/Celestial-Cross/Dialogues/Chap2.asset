  - guid: 9f5cba32-4994-4c4c-b677-5106bd7b0726
    nodeType: 1
    position: {x: 0, y: 0}
    speakerName: 
    dialogueText: A few minutes after arriving into the entrance hall Magnolia the
      principal is giving a speech about the attendance and the new arrival.
    characterSprite: {fileID: 0}
    sceneryId: interior
    choices: []
    conditionVariable: 
