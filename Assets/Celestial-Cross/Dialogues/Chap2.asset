  - guid: 08b4be6c-6a6e-4f8d-bbbf-a5fcffd38af2
    nodeType: 1
    position: {x: 0, y: 0}
    speakerName: 'Magnolia '
    dialogueText: Well dearest students, it is an honor to have you all here today.
    characterSprite: {fileID: 21300000, guid: b7d12cd161dca5a4ca2c791e691c0a13, type: 3}
    sceneryId: interior
    choices: []
    conditionVariable: 
    conditionValue: 
